# datadog_write_safety.rules
# Technology: datadog | Capability: write

rule datadog-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_datadog_PATTERN"
  MESSAGE "Blocked an unsafe pattern in datadog. Use the recommended best practices for 2025/2026."
}

rule datadog-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_datadog_API"
  MESSAGE "You are using an outdated API for datadog. Please upgrade to the newer API."
}
